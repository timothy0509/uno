generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String?
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games  GamePlayer[]
  stats  UserStat?
}

model UserStat {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  gamesPlayed Int    @default(0)
  gamesWon    Int    @default(0)
  totalKnockouts Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Game {
  id          String      @id @default(cuid())
  code        String?     @unique
  status      GameStatus  @default(WAITING)
  maxPlayers  Int         @default(6)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  startedAt   DateTime?
  endedAt     DateTime?
  
  deck            String    @default("[]")
  discardPile     String    @default("[]")
  currentPlayerIndex Int    @default(0)
  direction       Int       @default(1)
  drawPenalty     Int       @default(0)
  currentColor    String?
  lastPlayedCard   String?
  winner          String?
  
  players     GamePlayer[]
  actions     GameAction[]
}

model GamePlayer {
  id          String   @id @default(cuid())
  gameId      String
  userId      String
  name        String   @default("")
  position    Int
  cards       String   @default("[]")
  isKnockedOut Boolean @default(false)
  calledUno   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([gameId, userId])
  @@index([gameId])
}

model GameAction {
  id          String      @id @default(cuid())
  gameId      String
  playerId    String
  type        ActionType
  cardPlayed  String?
  cardsDrawn  Int        @default(0)
  targetId    String?
  color       String?
  createdAt   DateTime   @default(now())
  
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@index([gameId])
}

model Lobby {
  id          String      @id @default(cuid())
  code        String      @unique
  createdBy   String
  status      GameStatus  @default(WAITING)
  createdAt   DateTime    @default(now())
  
  players     LobbyPlayer[]
}

model LobbyPlayer {
  id          String   @id @default(cuid())
  lobbyId    String
  userId      String
  position    Int
  createdAt   DateTime @default(now())
  
  lobby       Lobby   @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  
  @@unique([lobbyId, userId])
  @@index([lobbyId])
}

enum GameStatus {
  WAITING
  PLAYING
  FINISHED
}

enum ActionType {
  PLAY
  DRAW
  STACK
  SWAP
  PASS_HANDS
  KNOCKOUT
  CALL_UNO
  WIN
}